# --- LLM (兼容 OpenAI 协议的自定义端点) ---
# 自定义端点必须设置 BASE_URL,例如:
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认 gpt-4o-mini 兼顾速度与成本,如需更高质量可改为 gpt-4o / gpt-4.1
OPENAI_MODEL=gpt-4o-mini
# 部分 OpenAI 兼容端点 (推理模型/自部署 vLLM) 不支持 response_format=json_object
# 设为 false 时,改用强 prompt 约束 + 防御性 JSON 解析
# (若你的端点报 'json_object' 错误,务必改为 false)
OPENAI_USE_JSON_FORMAT=true

# --- 并发控制 ---
# 单期文章并发编译上限,默认 8。视 API 配额调整
LLM_CONCURRENCY=8

# --- 图表图片视觉解析 (内嵌 paragraphs 里的 chart 段) ---
# auto  (推荐): 默认走多模态 (base64 内联图片),端点拒绝 image_url 时自动降级为纯文本
# true        : 强制走多模态,失败就报错
# false       : 彻底关闭视觉,只用 caption + alt + 上下文推断 (无视觉模型也能跑)
LLM_VISION_ENABLED=auto
# 多模态调用用的模型。默认复用 OPENAI_MODEL (gpt-4o-mini 支持 vision)。
# 若你的端点 vision 和 chat 是不同的部署,可在 LLM_VISION_MODEL 写专用模型名
# LLM_VISION_MODEL=gpt-4o-mini
# 图表图片在 base64 前的最长边 (像素),超过会自动等比缩放,控制 token 与成本
LLM_IMAGE_MAX_EDGE=1024

# --- 路径配置 ---
# 原始 .epub 投放目录 (kb_agent 常驻监听)
WATCH_DIR=./raw/imports
# 清洗后 .md 研报本地落盘目录
# 每期会在此目录下生成 {issue_date}/ 子目录,文件名格式: {标题}_{art_id}.md
OUTPUT_DIR=./output
# 前端 database.js 路径
DB_FILE=./frontend/database.js
# 封面/漫画/指标图持久化目录
# 默认写到 frontend/images/, 部署时随前端一起上传
IMAGE_DIR=./frontend/images
# 已处理 EPUB 去重库 (SQLite)
# 记录每个 EPUB 的 sha256, 重复投放会自动跳过 (不再调 LLM)
# 首次启动会自动从 raw/imports/archived/*.epub 迁移历史记录
STATE_DB_FILE=./frontend/state.db

# --- 守护进程轮询周期(秒) ---
POLL_INTERVAL=10

# --- 自动发布 (可选) ---
# AUTO_PUBLISH=1 时, kb_agent --once 编译完成后自动跑 scripts/publish.py
# AUTO_PUBLISH=1

# --- Netlify CLI 直推 (推荐, 多机协作无 git 冲突) ---
# 配齐下面两个变量后, publish.py 跳过 git commit + push, 直接 `netlify deploy --prod`
# 一次安装: npm install -g netlify-cli
# 一次登录 (或者用 token 跳过): netlify login
# Token 取自: Netlify 后台 → User settings → Applications → Personal access tokens
# Site ID 取自: Netlify 后台 → 你的站点 → Site settings → Site information → API ID
NETLIFY_AUTH_TOKEN=nfp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NETLIFY_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Git 远程仓库 (publish.py 自动检测, 兼容老流程) ---
# 仅在 NETLIFY_AUTH_TOKEN/SITE_ID 未配置时生效
# 适合"代码 push 到 GitHub → Netlify webhook 触发"的经典部署
# 适合多机器部署: 每台机器 .env 里写自己的仓库地址 (private 仓库)
# GIT_REMOTE_URL=https://github.com/<user>/<repo>.git
