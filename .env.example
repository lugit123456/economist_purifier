# --- LLM (兼容 OpenAI 协议的自定义端点) ---
# 自定义端点必须设置 BASE_URL,例如:
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认 gpt-4o-mini 兼顾速度与成本,如需更高质量可改为 gpt-4o / gpt-4.1
OPENAI_MODEL=gpt-4o-mini
# 部分 OpenAI 兼容端点 (推理模型/自部署 vLLM) 不支持 response_format=json_object
# 设为 false 时,改用强 prompt 约束 + 防御性 JSON 解析
# (若你的端点报 'json_object' 错误,务必改为 false)
OPENAI_USE_JSON_FORMAT=true

# --- 并发控制 ---
# 单期文章并发编译上限,默认 8。视 API 配额调整
LLM_CONCURRENCY=8

# --- 路径配置 ---
# 原始 .epub 投放目录 (kb_agent 常驻监听)
WATCH_DIR=./raw/imports
# 清洗后 .md 研报本地落盘目录
# 每期会在此目录下生成 {issue_date}/ 子目录,文件名格式: {标题}_{art_id}.md
OUTPUT_DIR=./output
# 前端 database.js 路径
DB_FILE=./frontend/database.js
# 封面图持久化目录
IMAGE_DIR=./raw/images

# --- 守护进程轮询周期(秒) ---
POLL_INTERVAL=7200