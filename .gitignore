# 经济学人智库清洗系统 — economist_purifier
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# 虚拟环境
venv/
.venv/
env/

# 环境变量 (包含 API Key,严禁提交)
.env
.env.local

# 原始数据与产物
raw/imports/*.epub
raw/imports/archived/
output/

# SQLite 处理记录库 (运行时自动生成,避免多人/多机冲突)
frontend/state.db
frontend/state.db-shm
frontend/state.db-wal

# 数据库与图片 (部署走 Netlify CLI 直推, 不进 git, 避免多机 git 冲突)
# 这些文件现在由 `netlify deploy --dir=.` 直接推到 Netlify, 不再走 git
# (旧数据如需清理: git rm -r --cached frontend/database.js frontend/images/)
frontend/database.js
frontend/images/

# Netlify CLI 部署排除清单 (与 .gitignore 类似, 但只作用于 `netlify deploy`)
.netlifyignore

# 系统
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/
*.swp

# 日志
*.log

# 开发态测试脚本 (非生产代码)
_*.py
!__init__.py