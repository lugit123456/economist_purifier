# 经济学人智库清洗系统 — economist_purifier
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# 虚拟环境
venv/
.venv/
env/

# 环境变量 (包含 API Key,严禁提交)
.env
.env.local

# 原始数据与产物
raw/imports/*.epub
raw/imports/archived/
output/

# 前端静态图片 - 全部跟踪 (需随 Netlify 部署,否则 deploy 时 404)
# 包括根目录封面图 (cover_*.jpg) 和子目录动态图 (cartoon/indicator)
# 一期约 1-3 MB, 50 期/年约 100 MB,完全在 git 可承受范围内

# 系统
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/
*.swp

# 日志
*.log

# 开发态测试脚本 (非生产代码)
_*.py
!__init__.py